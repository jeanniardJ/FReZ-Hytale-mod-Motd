$C = "../Common.ui";

$C.@DecoratedContainer {
    @Title = "Guide d'aide";
    Anchor: (Width: 750, Height: 560);
    @CloseButton #BoutonFermer {}

    Group {
        LayoutMode: Top;
        Padding: (Full: 16);

        Label #TitrePrincipal { 
            Text: "Guide d'aide"; 
            Style: (FontSize: 18); 
        }

        Label #SousTitre {
            Anchor: (Top: 20);
            Text: "Naviguez dans le sommaire pour afficher les sections disponibles."; 
            Style: (FontSize: 13);
        }

        Group {
            LayoutMode: Left;
            FlexWeight: 1;
            Padding: (Top: 12);

            // --- PANNEAU DE GAUCHE : SOMMAIRE ---
            Group #SommairePanel {
                Anchor: (Width: 200);
                LayoutMode: Top;
                Padding: (Left: 10);

                Label { 
                    Text: "Sommaire"; 
                    Padding: (Bottom: 6);
                }

                // Ré-ajout de l'élément manquant pour éviter le crash
                Label #SommaireVide {
                    Text: "";
                    Style: (FontSize: 12);
                }

                Group #SommaireList {
                    LayoutMode: TopScrolling;
                    FlexWeight: 1;
                    Background: #000000(0.1);
                    Padding: (Full: 4);
                }
            }

            // --- PANNEAU DE DROITE : DÉTAILS ---
            Group #DetailsPanel {
                FlexWeight: 1;
                LayoutMode: Top;
                Padding: (Left: 20);

                Label #DetailsTitre { 
                    Text: "Détails"; 
                    Padding: (Bottom: 4);
                }

                Label #DetailsResume { 
                    Text: ""; 
                    Padding: (Bottom: 8);
                }

                Group #DetailsBody {
                    LayoutMode: TopScrolling;
                    FlexWeight: 1;
                    Background: #000000(0.02);
                    Padding: (Full: 6);
                }

                // Ré-ajout également de DetailsEmpty qui pourrait aussi causer un crash
                Label #DetailsEmpty {
                    Text: "";
                    Style: (FontSize: 12);
                }
            }
        }
    }
}
